{
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "baseUrl": ".",
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": false,
    "emitDecoratorMetadata": false,
    "esModuleInterop": true,
    "exactOptionalPropertyTypes": false,
    "experimentalDecorators": false,
    "explainFiles": true,
    "forceConsistentCasingInFileNames": true,
    "importHelpers": true,
    "incremental": true,
    "isolatedModules": false,
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "noEmitOnError": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noPropertyAccessFromIndexSignature": true,
    "noUncheckedSideEffectImports": true,
    "outDir": "out-tsc",
    "paths": {
      "@the-stranger/eslint-plugin": ["./packages/eslint-plugin/src/index.ts"],
      "@the-stranger/eslint-plugin": ["./packages/eslint-plugin/src/index.ts", "./packages/eslint-plugin/src/utils.ts"],
      "@the-stranger/nx-plugin": ["./packages/nx-plugin/src/index.ts"],
      "@the-stranger/prettier-config": ["./packages/prettier-config/src/index.ts"],
      "@the-stranger/yarn-config": ["./packages/yarn-config/src/index.ts"]
    },
    "pretty": true,
    "removeComments": false,
    "resolveJsonModule": true,
    "rootDir": ".",
    "skipDefaultLibCheck": false,
    "skipLibCheck": true,
    "sourceMap": false,
    "strict": true,
    "target": "ES2024",
    "verbatimModuleSyntax": false
  },
  "exclude": ["node_modules", "tmp", "dist", "out-tsc", ".cache", ".yarn", ".nx", ".husky", ".github"]
}
