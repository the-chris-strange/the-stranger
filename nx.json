{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "generators": {
    "@nx/js": {
      "library": {
        "bundler": "tsc",
        "linter": "eslint",
        "unitTestRunner": "vitest",
        "useProjectJson": true
      }
    }
  },
  "nxCloudId": "67eeb7b904dc9617051c453f",
  "parallel": 7,
  "plugins": [
    {
      "plugin": "@nx/eslint/plugin",
      "options": {
        "targetName": "lint"
      }
    },
    {
      "plugin": "@nx/js/typescript",
      "options": {
        "build": {
          "buildDepsName": "build-deps",
          "configName": "tsconfig.lib.json",
          "targetName": "build",
          "watchDepsName": "watch-deps"
        },
        "typecheck": {
          "targetName": "typecheck"
        }
      }
    },
    {
      "plugin": "@nx/vite/plugin",
      "options": {
        "buildDepsTargetName": "build-deps",
        "buildTargetName": "build",
        "devTargetName": "dev",
        "previewTargetName": "preview",
        "serveStaticTargetName": "serve-static",
        "serveTargetName": "serve",
        "testTargetName": "test",
        "typecheckTargetName": "typecheck",
        "watchDepsTargetName": "watch-deps"
      }
    }
  ],
  "release": {
    "changelog": {
      "git": {
        "commit": false,
        "stageChanges": false,
        "tag": false
      },
      "projectChangelogs": true,
      "workspaceChangelog": {
        "createRelease": "github",
        "file": false
      }
    },
    "projectsRelationship": "independent",
    "version": {
      "currentVersionResolver": "git-tag",
      "fallbackCurrentVersionResolver": "disk",
      "git": {
        "commit": false,
        "stageChanges": false,
        "tag": false
      },
      "manifestRootsToUpdate": ["packages/{projectName}", "dist/packages/{projectName}"],
      "preserveLocalDependencyProtocols": false,
      "specifierSource": "conventional-commits",
      "versionPrefix": "^"
    }
  },
  "targetDefaults": {
    "@nx/js:tsc": {
      "cache": true,
      "dependsOn": ["^build"],
      "inputs": ["default", "^default"],
      "options": {
        "assets": [
          "{projectRoot}/*.md",
          {
            "glob": "**/*.md",
            "input": "{projectRoot}/docs",
            "output": "./docs"
          },
          {
            "glob": "package.json",
            "input": "{projectRoot}",
            "output": "."
          }
        ],
        "generatePackageJson": false,
        "main": "{projectRoot}/src/index.ts",
        "outputPath": "{workspaceRoot}/dist/{projectRoot}",
        "tsConfig": "{projectRoot}/tsconfig.lib.json"
      },
      "outputs": ["{options.outputPath}"]
    },
    "@the-stranger/nx-plugin:update-manifest": {
      "cache": true,
      "dependsOn": ["build"],
      "inputs": ["{projectRoot}/package.json", "{workspaceRoot}/dist/{projectRoot}/package.json"],
      "options": {
        "unset": ["main", "module", "types"]
      },
      "outputs": ["{workspaceRoot}/dist/{projectRoot}/package.json"]
    }
  }
}
