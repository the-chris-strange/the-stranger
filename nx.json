{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "generators": {
    "@nx/js": {
      "library": {
        "bundler": "tsc",
        "linter": "eslint",
        "unitTestRunner": "vitest",
        "useProjectJson": true
      }
    }
  },
  "namedInputs": {
    "default": ["{projectRoot}/**/*", "sharedGlobals"],
    "production": ["default", "!{projectRoot}/vite.config.*", "!{projectRoot}/vitest.config.*"],
    "sharedGlobals": ["{workspaceRoot}/tsconfig.json", "{workspaceRoot}/tsconfig.base.json"]
  },
  "nxCloudId": "67eeb7b904dc9617051c453f",
  "parallel": 7,
  "plugins": [
    {
      "plugin": "@nx/eslint/plugin",
      "options": {
        "targetName": "lint"
      }
    },
    {
      "plugin": "@nx/js/typescript",
      "options": {
        "build": {
          "buildDepsName": "build-deps",
          "configName": "tsconfig.lib.json",
          "targetName": "build",
          "watchDepsName": "watch-deps"
        },
        "typecheck": {
          "targetName": "typecheck"
        }
      }
    },
    {
      "plugin": "@nx/vitest",
      "options": {
        "testTargetName": "test"
      }
    }
  ],
  "release": {
    "changelog": {
      "git": {
        "commit": false,
        "stageChanges": false,
        "tag": false
      },
      "projectChangelogs": true,
      "workspaceChangelog": {
        "createRelease": "github",
        "file": false
      }
    },
    "projectsRelationship": "independent",
    "version": {
      "currentVersionResolver": "git-tag",
      "fallbackCurrentVersionResolver": "disk",
      "git": {
        "commit": false,
        "stageChanges": false,
        "tag": true
      },
      "manifestRootsToUpdate": ["{projectRoot}", "{workspaceRoot}/dist/{projectRoot}"],
      "preserveLocalDependencyProtocols": false,
      "specifierSource": "conventional-commits",
      "versionPrefix": "^"
    }
  },
  "sync": { "disabledTaskSyncGenerators": ["@nx/js:typescript-sync"] },
  "targetDefaults": {
    "@nx/js:tsc": {
      "cache": true,
      "dependsOn": ["^build"],
      "inputs": ["default", "^default"],
      "outputs": ["{options.outputPath}"],
      "options": {
        "assets": [
          "{projectRoot}/*.md",
          {
            "glob": "**/*.md",
            "input": "{projectRoot}/docs",
            "output": "./docs"
          },
          {
            "glob": "LICENSE",
            "input": "{workspaceRoot}",
            "output": ""
          },
          {
            "glob": "package.json",
            "input": "{projectRoot}",
            "output": "."
          }
        ],
        "generatePackageJson": true,
        "main": "{projectRoot}/src/index.ts",
        "outputPath": "{workspaceRoot}/dist/{projectRoot}",
        "tsConfig": "{projectRoot}/tsconfig.lib.json"
      }
    },
    "lint": {
      "inputs": [
        "default",
        "{workspaceRoot}/eslint.config.{js,mjs,cjs,ts,mts,cts}",
        "{projectRoot}/eslint.config.{js,mjs,cjs,ts,mts,cts}",
        "{workspaceRoot}/tools/eslint-rules/**/*",
        { "externalDependencies": ["eslint"] }
      ],
      "configurations": {
        "fix": {
          "args": ["--fix"]
        },
        "warnings": {
          "max-warnings": 0
        }
      }
    },
    "nx-release-publish": {
      "dependsOn": ["^nx-release-publish", "build"],
      "options": {
        "packageRoot": "{workspaceRoot}/dist/{projectRoot}"
      }
    },
    "test": {
      "inputs": ["default", { "externalDependencies": ["vitest"] }, { "env": "CI" }, { "env": "GITHUB_ACTIONS" }],
      "outputs": [
        "{workspaceRoot}/coverage/{projectRoot}/",
        "{workspaceRoot}/node_modules/.vitest/{projectRoot}/test-results.json"
      ],
      "configurations": {
        "coverage": {
          "args": ["--coverage"]
        }
      }
    },
    "typecheck": {
      "inputs": [
        "{workspaceRoot}/out-tsc/{projectRoot}/tsconfig.lib.tsbuildinfo",
        { "externalDependencies": ["typescript"] },
        { "dependentTasksOutputFiles": "**/*.d.ts" }
      ],
      "outputs": [
        "{workspaceRoot}/out-tsc/{projectRoot}/tsconfig.lib.tsbuildinfo",
        "{workspaceRoot}/dist/{projectRoot}/**/*.d.ts"
      ]
    }
  },
  "tui": {
    "autoExit": true
  }
}
