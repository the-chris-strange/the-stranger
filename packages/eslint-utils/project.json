{
  "name": "eslint-utils",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "packages/eslint-utils/src",
  "tags": ["npm:public"],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc"
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "inputs": ["default", "^default", { "externalDependencies": ["typescript"] }],
      "outputs": [
        "{workspaceRoot}/out-tsc/packages/eslint-utils",
        "{workspaceRoot}/out-tsc/packages/eslint-utils/tsconfig.lib.tsbuildinfo"
      ],
      "options": {
        "command": "tsc -b --force --emitDeclarationOnly tsconfig.lib.json",
        "cwd": "packages/eslint-utils"
      },
      "cache": true
    }
  }
}
