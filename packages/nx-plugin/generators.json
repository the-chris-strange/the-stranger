{
  "generators": {
    "cspell-config": {
      "description": "Generate a CSpell configuration file",
      "factory": "./src/generators/cspell-config/generator",
      "schema": "./src/generators/cspell-config/schema.json"
    },
    "error-class": {
      "description": "Generate a custom error class",
      "factory": "./src/generators/error-class/generator",
      "schema": "./src/generators/error-class/schema.json"
    },
    "eslint-config": {
      "description": "Generate an ESLint configuration file",
      "factory": "./src/generators/eslint-config/generator",
      "schema": "./src/generators/eslint-config/schema.json"
    },
    "jest-config": {
      "description": "Generate a jest configuration file",
      "factory": "./src/generators/jest-config/generator",
      "schema": "./src/generators/jest-config/schema.json"
    },
    "library": {
      "description": "Generate a JavaScript/TypeScript library with some customization",
      "factory": "./src/generators/library/generator",
      "schema": "./src/generators/library/schema.json"
    },
    "vite-config": {
      "description": "Generate a vite/vitest configuration file",
      "factory": "./src/generators/vite-config/generator",
      "schema": "./src/generators/vite-config/schema.json"
    }
  }
}
