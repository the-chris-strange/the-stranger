import { describe, expect, it } from 'vitest'

import { <%= className %> } from './<%= fileName %>'

describe('<%= className %>', () => {
  it('can be constructed', () => {
    expect(() => {
      new FileNotFoundError()
    }).not.toThrow()
  })

  it('sets the error name', () => {
    expect(new <%= className %>()).toHaveProperty('name', '<%= className %>')
  })
})
