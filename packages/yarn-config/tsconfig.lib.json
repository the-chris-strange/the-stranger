{
  "extends": ["./tsconfig.json"],
  "compilerOptions": {
    "declarationMap": false,
    "outDir": "../../dist",
    "tsBuildInfoFile": "../../out-tsc/packages/yarn-config/tsconfig.lib.tsbuildinfo",
    "types": ["node"],
    "verbatimModuleSyntax": false
  },
  "include": ["src/**/*.ts"],
  "exclude": [
    "vite.config.ts",
    "vite.config.mts",
    "vitest.config.ts",
    "vitest.config.mts",
    "src/**/*.test.ts",
    "src/**/*.spec.ts",
    "src/**/*.test.tsx",
    "src/**/*.spec.tsx",
    "src/**/*.test.js",
    "src/**/*.spec.js",
    "src/**/*.test.jsx",
    "src/**/*.spec.jsx",
    "src/test/**/*.ts"
  ]
}
