{
  "extends": ["./tsconfig.json"],
  "compilerOptions": {
    "declarationMap": false,
    "outDir": "../../out-tsc",
    "tsBuildInfoFile": "../../out-tsc/packages/eslint-config/tsconfig.lib.tsbuildinfo",
    "types": ["node"],
    "verbatimModuleSyntax": true
  },
  "include": ["src/**/*.ts"],
  "exclude": [
    "vite.config.ts",
    "vite.config.mts",
    "vitest.config.ts",
    "vitest.config.mts",
    "src/**/*.test.ts",
    "src/**/*.spec.ts",
    "src/**/*.test.tsx",
    "src/**/*.spec.tsx",
    "src/**/*.test.js",
    "src/**/*.spec.js",
    "src/**/*.test.jsx",
    "src/**/*.spec.jsx",
    "src/test/**/*.ts"
  ],
  "references": [{ "path": "../eslint-utils/tsconfig.lib.json" }]
}
