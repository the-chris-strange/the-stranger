{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "declaration": true,
    "outDir": "../../out-tsc",
    "tsBuildInfoFile": "../../out-tsc/tools/nx-plugin/tsconfig.lib.tsbuildinfo",
    "types": ["node"]
  },
  "include": ["src/**/*.ts"],
  "exclude": [
    "vite.config.ts",
    "vite.config.mts",
    "vitest.config.ts",
    "vitest.config.mts",
    "src/**/*.test.ts",
    "src/**/*.spec.ts",
    "src/**/*.test.tsx",
    "src/**/*.spec.tsx",
    "src/**/*.test.js",
    "src/**/*.spec.js",
    "src/**/*.test.jsx",
    "src/**/*.spec.jsx",
    "src/test/**/*.ts"
  ],
  "references": [
    { "path": "../../packages/nx-plugin/tsconfig.lib.json" },
    { "path": "../../packages/eslint-config/tsconfig.lib.json" }
  ]
}
